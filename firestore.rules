// firestore.rules
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin';
    }

    // ── Public read collections ──────────────────────────────────────────────

    // Blog: public can read published posts only; admins can read/write all
    match /blog/{docId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Events: public read, admin write
    match /events/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Products/shop: public read, admin write
    match /products/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Admin users ──────────────────────────────────────────────────────────

    // Any admin can read the admins list; only superadmins can write
    match /admins/{userId} {
      allow read: if isAdmin();
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin() && request.auth.uid != userId;
    }
  }
}
